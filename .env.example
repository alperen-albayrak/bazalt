# Copy to .env and fill in values
# docker compose will read this automatically

# Required
JWT_SECRET=change_me_to_a_long_random_string

# Optional overrides (defaults work for local dev)
POSTGRES_PASSWORD=bazalt_dev
S3_ACCESS_KEY=bazalt
S3_SECRET_KEY=bazalt_secret

# API base URL baked into the SPA at build time.
# Leave empty (default) — nginx serves both SPA and API from the same origin.
# Set to e.g. https://api.example.com if hosting the SPA on a CDN separately.
VITE_API_URL=
