    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "otplib": "^12.0.1",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
